# Server port (dev server and production static server)
PORT=3002

# webapi backend URL (proxied at /api in dev and prod)
WEBAPI_URL=http://localhost:3000

# web-view service account (server-only; must match webapi/.env)
WEBVIEW_USERNAME=website
WEBVIEW_PASSWORD=password

# Per-IP rate limit for /api proxy (requests per minute)
WEBVIEW_API_RATE_LIMIT_MAX=120
