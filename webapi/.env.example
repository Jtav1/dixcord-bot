# Server
PORT=3000
NODE_ENV=development

# Database: mysql or sqlite
DB_TYPE=sqlite

# MySQL (when DB_TYPE=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=api_template

# SQLite (when DB_TYPE=sqlite). Path to .sqlite file. Default: data/api_template.sqlite
 DB_FILE=./data/api_template.sqlite

# JWT (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
