# Server
PORT=3000
NODE_ENV=development

# Database: mysql or sqlite
DB_TYPE=sqlite

# MySQL (when DB_TYPE=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=api_db

# SQLite (when DB_TYPE=sqlite). Path to .sqlite file. Default: data/api_template.sqlite
DB_FILE=./data/api_db.sqlite

# JWT (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Admin panel login
ADMIN_USERNAME=user
ADMIN_PASSWORD=password

# Bot service account (discord-bot should use these for WEBAPI_USERNAME/PASSWORD)
BOT_USERNAME=bot
BOT_PASSWORD=bot-password

# Public web-view service account (read-only leaderboard/pin routes)
WEBVIEW_USERNAME=website
WEBVIEW_PASSWORD=password

# CORS allowed origins (comma-separated hostnames or full origins)
CORS_ORIGINS=192.168.0.2,dixbot-discord,localhost

# Authenticated API rate limit (requests per minute)
API_RATE_LIMIT_MAX=300

# Shared pin attachment files (defaults to ../discord-bot/files when unset)
# PIN_FILES_DIR=../discord-bot/files

