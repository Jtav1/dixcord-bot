{
  "name": "dixcord-bot-webapi",
  "version": "1.0.0",
  "description": "Express.js REST API for the dixcord-bot",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "db:init:mysql": "node scripts/mysql/initialize.js",
    "db:import:mysql": "node scripts/mysql/import.js",
    "db:setup:mysql": "node scripts/mysql/initialize.js && node scripts/mysql/import.js",
    "db:setup:sqlite": "node scripts/sqlite/setup.js",
    "db:migrate:mysql": "node scripts/mysql/initialize.js && node scripts/mysql/import.js",
    "db:migrate:sqlite": "node scripts/sqlite/setup.js"
  },
  "keywords": [
    "express",
    "mysql",
    "jwt",
    "rest-api"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.17.4"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.6.2"
  }
}
