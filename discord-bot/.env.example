# Everything in here needs to be provided as a docker env variable param

DEV_FLAG=1

DISCORD_GUILD_ID="discord-guild-id"
DISCORD_CLIENT_ID="discord-client-id"

DISCORD_TOKEN="discord-bot-token"
PERMISSIONS="discord-permissions-mask"

# Optional: text channel whose non-bot message authors are merged into user-mapping sync
DISCORD_USER_MAPPING_IMPORT_CHANNEL_ID=

# Web API (for bot to call your API; use same credentials as webapi ADMIN_*)
WEBAPI_URL=http://localhost:3000
WEBAPI_USERNAME=user
WEBAPI_PASSWORD=password

# Same as webapi: unset or true enables scheduled messages; false, 0, or no disables (no delivery, slash replies blocked).
# SCHEDULED_MESSAGE_ROUTES_ENABLED=false

# Container startup: when true/1/yes, clear all guild slash commands then re-register from commands/ (after API is healthy).
# With docker compose, set WEBAPI_URL to http://webapi:3000 so the bot reaches the API service.
DEPLOY_SLASH_COMMANDS=false